# Telegram credentials — get these at https://my.telegram.org → API development tools
TG_API_ID=
TG_API_HASH=

# Generated locally via: uv run python scripts/login.py
TG_SESSION=

# Comma-separated channels: numeric IDs or @usernames.
# The user account whose session is in TG_SESSION must already be a member of each channel.
CHANNEL_IDS=

# Postgres. Railway provides DATABASE_URL automatically when the Postgres plugin is attached.
# Both postgres:// and postgresql+asyncpg:// are accepted; the asyncpg driver is enforced at runtime.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tg_tail

# MinIO / S3-compatible storage
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=tg-tail-media
S3_REGION=us-east-1

# Behavior
LOG_LEVEL=INFO
LOG_FORMAT=json
MEDIA_CONCURRENCY=3
MEDIA_POLL_INTERVAL_SECONDS=5
MEDIA_MAX_ATTEMPTS=5
MEDIA_MAX_BYTES=104857600
